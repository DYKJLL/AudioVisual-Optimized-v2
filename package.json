{
  "name": "audiovisual",
  "version": "1.2.8",
  "description": "The key to unlock all streams. Optimized version with improved performance.",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "author": {
    "name": "AudioVisual",
    "email": "fenghaoran60@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "electron-log": "^5.2.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.void.player",
    "publish": {
      "provider": "generic",
      "url": "https://raw.githubusercontent.com/DYKJLL/AudioVisual-Optimized-v2/master/update/"
    },
    "productName": "AudioVisual",
    "files": [
      "main.js",
      "index.html",
      "package.json",
      "app-update.yml",
      "assets/**/*",
      "update/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "category": "AudioVideo"
    },
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true,
      "shortcutName": "AudioVisual 1.2.7",
      "include": "./build/installer.nsh",
      "deleteAppDataOnUninstall": false
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "output": "dist"
    }
  }
}
