{
  "name": "audiovisual",
  "version": "1.2.3",
  "description": "The key to unlock all streams. Optimized version with improved performance.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "author": {
    "name": "AudioVisual",
    "email": "fenghaoran60@gmail.com"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.void.player",
    "publish": {
      "provider": "github",
      "owner": "DYKJLL",
      "repo": "AudioVisual-Optimized-v2"
    },
    "productName": "AudioVisual",
    "files": [
      "main.js",
      "config.js",
      "index.html",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icon-512.png",
      "category": "AudioVideo"
    },
    "compression": "maximum",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "output": "dist"
    }
  }
}
